{
    "name": "lattice/routing",
    "description": "Attribute-based routing for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "routing",
        "attributes",
        "controllers",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/routing"
    },
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Routing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Routing\\Tests\\": "tests/"
        }
    }
}
